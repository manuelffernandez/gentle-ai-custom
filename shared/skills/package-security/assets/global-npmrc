# Global npm baseline (npm 11+)
# Protects ad-hoc npm usage on one workstation.
#
# Important: npm does not have a first-class built-in equivalent to
# pnpm's `allowBuilds` + `strictDepBuilds`, so `ignore-scripts=true`
# remains the strongest native baseline when the project can tolerate it.

ignore-scripts=true
allow-git=none
min-release-age=3
save-exact=true
