{
  "version": 1,
  "name": "gentle-ai-overlay-baseline",
  "description": "Runtime policy only: keep/prune baseline, inline-orchestrator sanitization, runtime overrides, and SDD profile reconciliation against a local config.",
  "maintenance": {
    "intent_file": "overlay/gentle-ai/policy/maintenance-intent.md",
    "state_file": "overlay/gentle-ai/state/upstream-state.json",
    "log_file": "overlay/gentle-ai/logs/update-log.md"
  },
  "upstream": {
    "repo_name": "gentle-ai",
    "orchestrator_prompt_path": "internal/assets/opencode/sdd-orchestrator.md"
  },
  "skills": {
    "keep": [
      "_shared",
      "cognitive-doc-design",
      "comment-writer",
      "go-testing",
      "judgment-day",
      "sdd-apply",
      "sdd-archive",
      "sdd-design",
      "sdd-explore",
      "sdd-init",
      "sdd-onboard",
      "sdd-propose",
      "sdd-spec",
      "sdd-tasks",
      "sdd-verify",
      "skill-creator",
      "skill-improver",
      "skill-registry"
    ],
    "prune": [
      "branch-pr",
      "chained-pr",
      "issue-creation",
      "work-unit-commits"
    ],
    "targets": [
      "~/.config/opencode/skills",
      "~/.claude/skills"
    ]
  },
  "opencode": {
    "config_path": "~/.config/opencode/opencode.json",
    "local_config_path": "~/.config/gentle-ai-custom/opencode-local-config.json",
    "legacy_profiles_local_config_path": "~/.config/gentle-ai-custom/opencode-sdd-profiles.json",
    "base_orchestrator_key": "gentle-orchestrator",
    "generated_orchestrators_dir": "~/.config/opencode/prompts/sdd/orchestrators",
    "orchestrator_snapshot_dir": "overlay/gentle-ai/snapshots/upstream/opencode/orchestrators",
    "orchestrator_snapshot_metadata_file": "overlay/gentle-ai/snapshots/upstream/opencode/orchestrators/gentle-orchestrator.last.meta.yaml",
    "local_orchestrator_snapshot_dir": "~/.config/gentle-ai-custom/opencode-orchestrator-snapshots",
    "orchestrator_agent_keys": [
      "gentle-orchestrator"
    ],
    "orchestrator_agent_prefixes": [
      "sdd-orchestrator"
    ],
    "profile_orchestrator_prefix": "sdd-orchestrator-",
    "sdd_phases": [
      "sdd-init",
      "sdd-explore",
      "sdd-propose",
      "sdd-spec",
      "sdd-design",
      "sdd-tasks",
      "sdd-apply",
      "sdd-verify",
      "sdd-archive",
      "sdd-onboard"
    ]
  },
  "sanitizer": {
    "required_markers": [
      "## Model Assignments",
      "### Sub-Agent Launch Pattern",
      "Required preflight choices:"
    ],
    "forbidden_markers": [
      "C. PRs",
      "D. Review",
      "### Delivery Strategy",
      "### Chain Strategy",
      "### Review Workload Guard (MANDATORY)"
    ]
  }
}
