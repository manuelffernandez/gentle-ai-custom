{
  "version": 1,
  "name": "gentle-ai-overlay-baseline",
  "description": "Runtime policy only: keep/prune baseline, built-in overrides, and SDD profile reconciliation against a local config.",
  "maintenance": {
    "intent_file": "overlay/gentle-ai/policy/maintenance-intent.md",
    "state_file": "overlay/gentle-ai/state/upstream-state.json",
    "log_file": "overlay/gentle-ai/logs/update-log.md"
  },
  "upstream": {
    "repo_name": "gentle-ai",
    "orchestrator_prompt_path": "internal/assets/opencode/sdd-orchestrator.md"
  },
  "skills": {
    "keep": [
      "_shared",
      "cognitive-doc-design",
      "comment-writer",
      "go-testing",
      "judgment-day",
      "sdd-apply",
      "sdd-archive",
      "sdd-design",
      "sdd-explore",
      "sdd-init",
      "sdd-onboard",
      "sdd-propose",
      "sdd-spec",
      "sdd-tasks",
      "sdd-verify",
      "skill-creator",
      "skill-improver",
      "skill-registry"
    ],
    "prune": [
      "branch-pr",
      "chained-pr",
      "issue-creation",
      "work-unit-commits"
    ]
  },
  "opencode": {
    "config_path": "~/.config/opencode/opencode.json",
    "local_config_path": "~/.config/gentle-ai-custom/opencode-local-config.json",
    "base_orchestrator_key": "gentle-orchestrator",
    "orchestrator_agent_keys": [
      "gentle-orchestrator"
    ],
    "orchestrator_agent_prefixes": [
      "sdd-orchestrator"
    ],
    "profile_orchestrator_prefix": "sdd-orchestrator-",
    "sdd_phases": [
      "sdd-init",
      "sdd-explore",
      "sdd-propose",
      "sdd-spec",
      "sdd-design",
      "sdd-tasks",
      "sdd-apply",
      "sdd-verify",
      "sdd-archive",
      "sdd-onboard"
    ]
  }
}
