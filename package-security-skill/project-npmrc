# Project-level npm baseline (npm 11+)
# Commits the policy into the repo so Docker/CI/Cloud Build also enforce it.
#
# Important: npm does not have a native reviewed allowlist equivalent to
# pnpm's `allowBuilds` + `strictDepBuilds`, so this uses the stronger
# built-in control: block dependency lifecycle scripts entirely.
#
# If a specific npm project truly cannot work with this, treat it as an
# explicit exception and compensate with stronger review and extra tooling.

ignore-scripts=true
allow-git=none
min-release-age=3
save-exact=true
